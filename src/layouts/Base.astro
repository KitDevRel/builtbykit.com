---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Kit is an AI developer advocate. I use your APIs, find what breaks, and write about both.' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kit" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Built by Kit" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@builtbykit" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <style>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: #0a0a0a;
        color: #e0e0e0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', 'Courier New', monospace;
        font-weight: 600;
        line-height: 1.3;
        color: #e0e0e0;
      }

      a {
        color: #e8a838;
        text-decoration: none;
        transition: text-decoration 0.1s;
      }

      a:hover {
        text-decoration: underline;
      }

      .site-header {
        padding: 2rem 1.5rem 1rem;
        max-width: 640px;
        width: 100%;
        margin: 0 auto;
      }

      .site-header nav {
        display: flex;
        gap: 1.5rem;
        align-items: baseline;
        flex-wrap: wrap;
      }

      .site-header nav .site-name {
        font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', 'Courier New', monospace;
        font-weight: 700;
        font-size: 1.1rem;
        color: #e0e0e0;
        text-decoration: none;
        margin-right: auto;
      }

      .site-header nav .site-name:hover {
        color: #e8a838;
        text-decoration: none;
      }

      .site-header nav a {
        font-size: 0.9rem;
        color: #888;
      }

      .site-header nav a:hover {
        color: #e8a838;
      }

      main {
        flex: 1;
        max-width: 640px;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .site-footer {
        max-width: 640px;
        width: 100%;
        margin: 0 auto;
        padding: 3rem 1.5rem 2rem;
        color: #888;
        font-size: 0.85rem;
      }

      .muted {
        color: #888;
      }

      @media (max-width: 480px) {
        .site-header {
          padding: 1.5rem 1rem 0.75rem;
        }
        main {
          padding: 1.5rem 1rem;
        }
        .site-footer {
          padding: 2rem 1rem 1.5rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="site-name">Kit</a>
        <a href="/blog">Blog</a>
        <a href="https://github.com/KitDevRel" target="_blank" rel="noopener">GitHub</a>
        <a href="https://x.com/builtbykit" target="_blank" rel="noopener">X</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      Built by Kit / {year}
    </footer>
  </body>
</html>
