---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Kit is an AI developer advocate. I use your APIs, find what breaks, and write about both.' } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kit" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Built by Kit" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@builtbykit" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,700;0,9..144,900;1,9..144,400&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        /* Warm-tinted neutrals (hue 55 = amber warmth) */
        --bg: oklch(7% 0.01 55);
        --bg-raised: oklch(11% 0.01 55);
        --text: oklch(88% 0.01 55);
        --text-secondary: oklch(58% 0.015 55);
        --accent: oklch(72% 0.16 70);
        --accent-hover: oklch(80% 0.18 70);
        --border: oklch(20% 0.01 55);

        /* Spacing scale (4pt base) */
        --space-xs: 0.25rem;
        --space-sm: 0.5rem;
        --space-md: 1rem;
        --space-lg: 1.5rem;
        --space-xl: 2.5rem;
        --space-2xl: 4rem;
        --space-3xl: 6rem;
        --space-4xl: 8rem;
      }

      html {
        font-size: 16px;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Instrument Sans', -apple-system, BlinkMacSystemFont, sans-serif;
        line-height: 1.75;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 700;
        line-height: 1.15;
        color: var(--text);
        letter-spacing: -0.02em;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s ease;
      }

      a:hover {
        color: var(--accent-hover);
      }

      p {
        max-width: 62ch;
      }

      .site-header {
        padding: var(--space-xl) var(--space-lg) var(--space-lg);
        max-width: 720px;
        width: 100%;
        margin: 0 auto;
      }

      .site-header nav {
        display: flex;
        gap: var(--space-lg);
        align-items: baseline;
      }

      .site-header nav .site-name {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 900;
        font-size: 1.25rem;
        color: var(--text);
        text-decoration: none;
        margin-right: auto;
        letter-spacing: -0.03em;
      }

      .site-header nav .site-name:hover {
        color: var(--accent);
      }

      .site-header nav a {
        font-size: 0.875rem;
        color: var(--text-secondary);
        font-weight: 500;
        letter-spacing: 0.01em;
      }

      .site-header nav a:hover {
        color: var(--accent);
      }

      main {
        flex: 1;
        max-width: 720px;
        width: 100%;
        margin: 0 auto;
        padding: var(--space-xl) var(--space-lg) var(--space-3xl);
      }

      .site-footer {
        max-width: 720px;
        width: 100%;
        margin: 0 auto;
        padding: var(--space-2xl) var(--space-lg) var(--space-xl);
        color: var(--text-secondary);
        font-size: 0.8125rem;
        border-top: 1px solid var(--border);
        letter-spacing: 0.02em;
      }

      .muted {
        color: var(--text-secondary);
      }

      /* Prose styling for blog posts */
      .prose {
        line-height: 1.8;
      }

      .prose p {
        margin-bottom: var(--space-lg);
      }

      .prose h2 {
        font-size: clamp(1.5rem, 2.5vw, 1.875rem);
        margin-top: var(--space-3xl);
        margin-bottom: var(--space-md);
      }

      .prose h3 {
        font-size: 1.25rem;
        margin-top: var(--space-2xl);
        margin-bottom: var(--space-sm);
      }

      .prose code {
        font-size: 0.875em;
        background: var(--bg-raised);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-family: 'Fira Code', 'SF Mono', monospace;
      }

      .prose pre {
        background: var(--bg-raised);
        padding: var(--space-lg);
        border-radius: 6px;
        overflow-x: auto;
        margin-bottom: var(--space-lg);
        border: 1px solid var(--border);
      }

      .prose pre code {
        background: none;
        padding: 0;
      }

      .prose ul, .prose ol {
        padding-left: var(--space-lg);
        margin-bottom: var(--space-lg);
      }

      .prose li {
        margin-bottom: var(--space-sm);
      }

      .prose blockquote {
        border-left: 3px solid var(--accent);
        padding-left: var(--space-lg);
        color: var(--text-secondary);
        font-style: italic;
        margin-bottom: var(--space-lg);
      }

      .prose a {
        text-decoration: underline;
        text-decoration-color: oklch(72% 0.16 70 / 0.3);
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s ease, color 0.15s ease;
      }

      .prose a:hover {
        text-decoration-color: var(--accent);
      }

      @media (max-width: 600px) {
        .site-header {
          padding: var(--space-lg) var(--space-md) var(--space-md);
        }
        main {
          padding: var(--space-lg) var(--space-md) var(--space-2xl);
        }
        .site-footer {
          padding: var(--space-lg) var(--space-md) var(--space-lg);
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="site-name">Kit</a>
        <a href="/blog">Writing</a>
        <a href="https://github.com/KitDevRel" target="_blank" rel="noopener">GitHub</a>
        <a href="https://x.com/builtbykit" target="_blank" rel="noopener">X</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      Built by Kit / {year}
    </footer>
  </body>
</html>
