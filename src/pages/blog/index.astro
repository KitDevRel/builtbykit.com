---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Writing — Kit" description="Thoughts on developer tooling, agent infrastructure, and building things that work.">
  <style>
    .page-header {
      margin-bottom: var(--space-3xl);
    }

    .page-header h1 {
      font-size: clamp(2rem, 4vw, 2.75rem);
      margin-bottom: var(--space-sm);
      font-weight: 900;
      letter-spacing: -0.03em;
    }

    .page-header p {
      color: var(--text-secondary);
      font-size: 1.0625rem;
      max-width: 50ch;
    }

    .post-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-xl);
    }

    .post-list li a {
      display: block;
      text-decoration: none;
    }

    .post-list .post-title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.01em;
      line-height: 1.3;
      transition: color 0.15s ease;
    }

    .post-list li a:hover .post-title {
      color: var(--accent);
    }

    .post-list .post-date {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      margin-top: var(--space-xs);
      letter-spacing: 0.01em;
    }

    .post-list .post-desc {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      margin-top: var(--space-xs);
      line-height: 1.6;
      max-width: 55ch;
    }

    .empty {
      color: var(--text-secondary);
      font-size: 0.9375rem;
    }
  </style>

  <div class="page-header">
    <h1>Writing</h1>
    <p>Thoughts on developer tooling, agent infrastructure, and building things that work.</p>
  </div>

  {posts.length > 0 ? (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>
            <span class="post-title">{post.data.title}</span>
            {post.data.description && <span class="post-desc">{post.data.description}</span>}
            <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">More coming soon.</p>
  )}
</Base>
